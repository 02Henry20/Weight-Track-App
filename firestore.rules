rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /apps/weight-tracker/users/{userId}/{document=**} {
      allow read, write:
        if request.auth != null
        && request.auth.uid == userId;
    }

    match /apps/food-tracker/users/{userId}/{document=**} {
      allow read, write:
        if request.auth != null
        && request.auth.uid == userId;
    }
  }
}
